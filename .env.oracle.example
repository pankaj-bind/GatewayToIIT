# =============================================================================
# GatewayToIIT - Oracle Cloud Production Environment
# =============================================================================
# Copy this file to `.env` on the Oracle VM and fill every required value.
#   cp .env.oracle.example .env
#   nano .env
#
# NEVER commit the real .env. It is in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Public hostname for the API + the VM's public IP.
# DuckDNS (free) is the recommended path: create a subdomain at
# https://www.duckdns.org and point it at PUBLIC_IP.
# -----------------------------------------------------------------------------
DOMAIN=your-subdomain.duckdns.org
PUBLIC_IP=YOUR.VM.PUBLIC.IP
LETSENCRYPT_EMAIL=you@example.com

# -----------------------------------------------------------------------------
# Frontend origin (Vercel). Used for CORS + CSRF allow-lists.
# Preview deploys (*.vercel.app) are handled by a regex in settings.py.
# -----------------------------------------------------------------------------
FRONTEND_ORIGIN=https://your-app.vercel.app

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=CHANGE-ME-TO-A-50-CHAR-RANDOM-STRING

# Gunicorn sizing. Default 3x2=6 concurrent is fine for small traffic. Bump
# workers to 4 and timeout higher if video uploads / FFmpeg jobs are slow.
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=300

# -----------------------------------------------------------------------------
# Single-user lockdown
# -----------------------------------------------------------------------------
# Signup endpoint returns 403 unless SIGNUP_ENABLED=True. Keep it False in
# production once your account exists.
SIGNUP_ENABLED=False

# Comma-separated email allow-list. Empty/unset = no restriction. When set,
# only these emails can log in (other accounts in the DB are locked out).
ALLOWED_LOGIN_EMAILS=you@example.com

# -----------------------------------------------------------------------------
# Google Drive (videos are uploaded here, then served via API proxy)
# -----------------------------------------------------------------------------
# You upload two JSON files to the VM at ./backend/credentials.json and
# ./backend/token.json; they are mounted read-only into the container.
# Only the Drive *folder id* for the uploads is set via env.
GOOGLE_DRIVE_FOLDER_ID=

# -----------------------------------------------------------------------------
# Telegram (Telethon integration)
#   Get credentials at https://my.telegram.org/apps
# -----------------------------------------------------------------------------
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
